{
  "name": "@homelabconnect/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "api": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/db/migrate.ts",
    "db:seed": "tsx src/infrastructure/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@homelabconnect/shared": "workspace:*",
    "@orpc/server": "1.14.4",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "drizzle-orm": "0.38.4",
    "express": "4.21.1",
    "jsonwebtoken": "9.0.2",
    "postgres": "3.4.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.16.11",
    "drizzle-kit": "0.30.6",
    "tsx": "4.19.1",
    "typescript": "5.6.3"
  }
}
