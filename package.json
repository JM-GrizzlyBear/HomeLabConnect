{
  "name": "HomeLabConnect",
  "version": "0.1.0",
  "private": true,
  "description": "HomeLabConnect — Clean Architecture monorepo (Next.js + Express + oRPC + Drizzle + Postgres)",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "api": "turbo run api",
    "client": "turbo run client",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@hlc/api",
    "db:migrate": "turbo run db:migrate --filter=@hlc/api",
    "db:seed": "turbo run db:seed --filter=@hlc/api",
    "db:reset": "docker compose down -v && docker compose up -d db && sleep 3 && pnpm db:migrate && pnpm db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build"
  },
  "devDependencies": {
    "turbo": "2.1.3",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
