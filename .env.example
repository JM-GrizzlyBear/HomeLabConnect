# ============================================================
# HomeLabConnect environment variables
# Copy this file to .env and fill in values.
# Docker Compose reads from .env automatically.
# ============================================================

# --- Postgres (used by the `db` service in docker-compose) ---
POSTGRES_USER=homelabconnect
POSTGRES_PASSWORD=homelabconnectpass
POSTGRES_DB=homelabconnect
POSTGRES_PORT=5433

# --- API (Express + oRPC) ---
API_PORT=4000
# When the API runs INSIDE docker, the DB host is the service name "db".
# When you run the API locally on your machine (outside docker), use "localhost".
DATABASE_URL=postgres://homelabconnect:homelabconnectpass@db:5433/homelabconnect

# JWT secret — generate a long random string in real projects:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Web (Next.js) ---
WEB_PORT=3000
# Browser-visible URL of the API (must be reachable from the user's browser)
NEXT_PUBLIC_API_URL=http://localhost:4000
